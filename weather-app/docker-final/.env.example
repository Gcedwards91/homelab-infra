# Copy this file to .env and fill in your values
# Do not commit .env to version control

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Domain configuration
# Locally: leave as localhost
# AWS: set to your actual domain e.g. your-domain.com
DOMAIN=localhost

# Grafana URL — constructed from DOMAIN
# Locally: http://localhost/grafana
# AWS: https://your-domain.com/grafana
GRAFANA_URL=http://localhost/grafana

# Prometheus URL — constructed from DOMAIN
# Locally: http://localhost/prometheus/
# AWS: https://your-domain.com/prometheus/
PROMETHEUS_URL=http://localhost/prometheus/

# Flask session secret key — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-generate-a-real-secret

# Playground rolling passphrase seed — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Changing this value invalidates all current passphrases immediately.
PLAYGROUND_SECRET=change-me-generate-a-real-secret

# Playground admin key — protects GET /playground/passphrase
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PLAYGROUND_ADMIN_KEY=change-me-generate-a-real-secret
